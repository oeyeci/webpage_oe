---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MediaImage from '../../components/ui/MediaImage.astro';
import { getDb, getEnv, getUser } from '../../lib/context';
import { getActivityBySlug, listActivities } from '../../lib/repositories/activities';
import { absoluteUrl, breadcrumbSchema, eventSchema, metaDescription } from '../../lib/seo';
import { mediaUrl } from '../../lib/storage/r2';
import { formatLongDate } from '../../lib/utils/date';

const db = getDb();
const env = getEnv();
const user = getUser(Astro);

const slug = Astro.params.slug!;
const activity = await getActivityBySlug(db, slug, { includeUnpublished: Boolean(user) });

if (!activity) {
  return Astro.rewrite('/404');
}

const more = (await listActivities(db, { limit: 4 })).filter((a) => a.id !== activity.id).slice(0, 3);

const coverUrl = activity.cover
  ? absoluteUrl(mediaUrl(activity.cover.r2Key, env.MEDIA_PUBLIC_BASE), env.PUBLIC_SITE_URL)
  : undefined;
---

<BaseLayout
  title={activity.title}
  description={metaDescription(activity.excerpt ?? activity.descriptionHtml, activity.title)}
  image={coverUrl}
  type="article"
  noindex={!activity.isPublished}
  schemas={[
    breadcrumbSchema(
      [
        { name: 'Home', url: '/' },
        { name: 'Activities', url: '/activities' },
        { name: activity.title, url: `/activities/${activity.slug}` },
      ],
      env.PUBLIC_SITE_URL,
    ),
    eventSchema(activity, env.PUBLIC_SITE_URL, coverUrl),
  ]}
>
  {
    !activity.isPublished && (
      <div class="border-b border-warning/30 bg-warning/10">
        <p class="container-page py-2.5 text-center text-sm font-medium text-warning">
          Draft preview — this activity is not publicly visible.
        </p>
      </div>
    )
  }

  <article class="container-page pt-12 pb-20 md:pt-16">
    <header class="mx-auto max-w-[44rem]">
      <nav aria-label="Breadcrumb" class="mb-6">
        <a
          href="/activities"
          class="inline-flex items-center gap-1.5 text-sm text-ink-muted transition-colors hover:text-ink"
        >
          <svg
            class="size-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M19 12H5M11 18l-6-6 6-6"></path>
          </svg>
          All activities
        </a>
      </nav>

      <div class="flex flex-wrap items-center gap-2 text-sm text-ink-subtle">
        {
          activity.category && (
            <span class="chip chip-accent !py-0.5 !text-xs">{activity.category.name}</span>
          )
        }
        <time datetime={activity.activityDate}>{formatLongDate(activity.activityDate)}</time>
        {
          activity.endDate && activity.endDate !== activity.activityDate && (
            <>
              <span aria-hidden="true">→</span>
              <time datetime={activity.endDate}>{formatLongDate(activity.endDate)}</time>
            </>
          )
        }
      </div>

      <h1 class="mt-4 text-[2.25rem] leading-[1.12] tracking-[-0.025em] md:text-[2.75rem]">
        {activity.title}
      </h1>

      {
        activity.location && (
          <p class="mt-4 flex items-center gap-2 text-base text-ink-muted">
            <svg
              class="size-4 shrink-0"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              aria-hidden="true"
            >
              <path d="M12 21s-7-5.5-7-11a7 7 0 1114 0c0 5.5-7 11-7 11z" />
              <circle cx="12" cy="10" r="2.5" />
            </svg>
            {activity.location}
          </p>
        )
      }

      {
        activity.url && (
          <a
            href={activity.url}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-secondary mt-6"
          >
            Visit event page
            <span class="sr-only">(opens in a new tab)</span>
          </a>
        )
      }
    </header>

    {
      activity.cover && (
        <figure class="mx-auto mt-10 max-w-4xl">
          <MediaImage
            media={activity.cover}
            priority
            sizes="(min-width: 1024px) 56rem, 100vw"
            class="aspect-video w-full rounded-2xl border border-line object-cover shadow-card"
          />
          {activity.cover.caption && (
            <figcaption class="mt-3 text-center text-sm text-ink-subtle">
              {activity.cover.caption}
            </figcaption>
          )}
        </figure>
      )
    }

    {
      activity.descriptionHtml && (
        <div class="mx-auto mt-12 max-w-[44rem]">
          <div class="prose" set:html={activity.descriptionHtml} />
        </div>
      )
    }

    {/* ═══ Gallery ══════════════════════════════════════════════════════ */}
    {
      activity.gallery.length > 0 && (
        <section class="mx-auto mt-14 max-w-4xl">
          <h2 class="font-serif text-2xl font-semibold">Gallery</h2>
          <ul class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {activity.gallery.map((image) => (
              <li>
                <figure>
                  <MediaImage
                    media={image}
                    sizes="(min-width: 1024px) 18rem, (min-width: 640px) 45vw, 100vw"
                    class="aspect-4/3 w-full rounded-xl border border-line object-cover"
                  />
                  {image.caption && (
                    <figcaption class="mt-2 text-sm text-ink-subtle">{image.caption}</figcaption>
                  )}
                </figure>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>

  {
    more.length > 0 && (
      <section class="border-t border-line bg-surface">
        <div class="container-page py-16">
          <h2 class="font-serif text-2xl font-semibold">More activities</h2>
          <ul class="mt-8 grid gap-5 md:grid-cols-3">
            {more.map((item) => (
              <li class="card card-interactive group p-5">
                <time datetime={item.activityDate} class="font-mono text-xs text-ink-subtle">
                  {formatLongDate(item.activityDate)}
                </time>
                <h3 class="mt-2 text-base leading-snug">
                  <a
                    href={`/activities/${item.slug}`}
                    class="transition-colors group-hover:text-accent"
                  >
                    {item.title}
                  </a>
                </h3>
                {item.location && (
                  <p class="mt-1.5 truncate text-sm text-ink-muted">{item.location}</p>
                )}
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }
</BaseLayout>
