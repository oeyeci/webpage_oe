---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import ContactForm from '../components/contact/ContactForm';
import SocialLink from '../components/ui/SocialLink.astro';
import { getDb, getEnv } from '../lib/context';
import { getProfile } from '../lib/repositories/about';
import { getSettings } from '../lib/repositories/settings';
import { breadcrumbSchema } from '../lib/seo';
import { socialLinks } from '../lib/site';

const db = getDb();
const env = getEnv();

const [profile, settings] = await Promise.all([getProfile(db), getSettings(db)]);
const socials = profile ? socialLinks(profile) : [];
const formEnabled = settings['contact.enabled'];

// An embedded Google Map is a third-party iframe that costs ~900 KB and sets
// cookies. We link out to it instead and render a lightweight static card —
// which is also the only way to keep a clean CSP and a 100 privacy score.
const mapsUrl =
  profile?.googleMapsUrl ??
  (profile?.address
    ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(profile.address)}`
    : null);

const details = [
  profile?.email && {
    label: 'Email',
    value: profile.email,
    href: `mailto:${profile.email}`,
    icon: 'mail',
  },
  profile?.office && { label: 'Office', value: profile.office, href: null, icon: 'building' },
  profile?.address && {
    label: 'Address',
    value: profile.address,
    href: mapsUrl,
    icon: 'pin',
  },
].filter(Boolean) as Array<{
  label: string;
  value: string;
  href: string | null;
  icon: string;
}>;
---

<BaseLayout
  title="Contact"
  description="Get in touch about research collaborations, graduate supervision, peer review or speaking invitations."
  schemas={[
    breadcrumbSchema(
      [
        { name: 'Home', url: '/' },
        { name: 'Contact', url: '/contact' },
      ],
      env.PUBLIC_SITE_URL,
    ),
  ]}
>
  <PageHeader
    eyebrow="Get in touch"
    title="Contact"
    lead="Research collaborations, graduate supervision, peer review, speaking invitations — or just to say hello."
  />

  <div class="container-page pb-24">
    <div class="grid gap-10 lg:grid-cols-[1fr_22rem] lg:gap-14">
      {/* ═══ Form ═════════════════════════════════════════════════════════ */}
      <div class="reveal order-2 lg:order-1">
        {
          formEnabled ? (
            <ContactForm siteKey={env.PUBLIC_TURNSTILE_SITE_KEY} client:load />
          ) : (
            <div class="card p-8 text-center">
              <h2 class="font-serif text-xl font-semibold">The contact form is closed</h2>
              <p class="mx-auto mt-2 max-w-sm text-ink-muted">
                Please reach me by email in the meantime.
              </p>
              {profile?.email && (
                <a href={`mailto:${profile.email}`} class="btn btn-primary mt-6">
                  {profile.email}
                </a>
              )}
            </div>
          )
        }
      </div>

      {/* ═══ Details ══════════════════════════════════════════════════════ */}
      <aside class="reveal order-1 space-y-5 lg:order-2">
        <div class="card p-6">
          <h2 class="font-sans text-xs font-semibold uppercase tracking-wider text-ink-subtle">
            Contact details
          </h2>

          <dl class="mt-5 space-y-5">
            {
              details.map((detail) => (
                <div class="flex gap-3">
                  <span
                    class="mt-0.5 grid size-8 shrink-0 place-items-center rounded-lg bg-surface-2 text-ink-muted"
                    aria-hidden="true"
                  >
                    {detail.icon === 'mail' && (
                      <svg
                        class="size-4"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.75"
                      >
                        <rect x="3" y="5" width="18" height="14" rx="2" />
                        <path d="M3 7l9 6 9-6" />
                      </svg>
                    )}
                    {detail.icon === 'building' && (
                      <svg
                        class="size-4"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.75"
                      >
                        <rect x="4" y="3" width="16" height="18" rx="1.5" />
                        <path d="M9 8h.01M15 8h.01M9 12h.01M15 12h.01M10 21v-4h4v4" />
                      </svg>
                    )}
                    {detail.icon === 'pin' && (
                      <svg
                        class="size-4"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.75"
                      >
                        <path d="M12 21s-7-5.5-7-11a7 7 0 1114 0c0 5.5-7 11-7 11z" />
                        <circle cx="12" cy="10" r="2.5" />
                      </svg>
                    )}
                  </span>

                  <div class="min-w-0">
                    <dt class="text-xs text-ink-subtle">{detail.label}</dt>
                    <dd class="mt-0.5 text-sm leading-relaxed break-words">
                      {detail.href ? (
                        <a
                          href={detail.href}
                          class="font-medium text-ink transition-colors hover:text-accent"
                          target={detail.href.startsWith('http') ? '_blank' : undefined}
                          rel={
                            detail.href.startsWith('http') ? 'noopener noreferrer' : undefined
                          }
                        >
                          {detail.value}
                        </a>
                      ) : (
                        <span class="font-medium">{detail.value}</span>
                      )}
                    </dd>
                  </div>
                </div>
              ))
            }
          </dl>

          {
            mapsUrl && (
              <a
                href={mapsUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-secondary mt-6 w-full"
              >
                <svg
                  class="size-4"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.75"
                  aria-hidden="true"
                >
                  <path d="M9 20l-5.5 2V6L9 4m0 16l6-2m-6 2V4m6 14l5.5 2V6L15 4m0 14V4m0 0L9 6" />
                </svg>
                Open in Google Maps
                <span class="sr-only">(opens in a new tab)</span>
              </a>
            )
          }
        </div>

        {/* ═══ Academic profiles ═════════════════════════════════════════ */}
        {
          socials.length > 0 && (
            <div class="card p-6">
              <h2 class="font-sans text-xs font-semibold uppercase tracking-wider text-ink-subtle">
                Find me elsewhere
              </h2>
              <ul class="mt-4 space-y-1">
                {socials
                  .filter((social) => social.brand !== 'email')
                  .map((social) => (
                    <li>
                      <SocialLink
                        brand={social.brand}
                        label={social.label}
                        href={social.href}
                        variant="row"
                      />
                    </li>
                  ))}
              </ul>
            </div>
          )
        }

        <p class="px-1 text-xs leading-relaxed text-ink-subtle">
          I aim to reply within a few working days. For urgent matters concerning students,
          please use my institutional email.
        </p>
      </aside>
    </div>
  </div>
</BaseLayout>
