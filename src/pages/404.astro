---
import BaseLayout from '../layouts/BaseLayout.astro';
import { NAV_ITEMS } from '../lib/site';
---

<BaseLayout
  title="Page not found"
  description="The page you were looking for does not exist."
  noindex
  bareSchema
>
  <section class="container-page flex min-h-[70vh] flex-col items-center justify-center py-20 text-center">
    <p class="font-mono text-sm font-semibold tracking-widest text-accent">404</p>

    <h1 class="mt-5 text-4xl md:text-6xl">This page doesn&rsquo;t exist</h1>

    <p class="mt-5 max-w-md text-lg leading-relaxed text-ink-muted">
      The link may be broken, or the page may have moved. Here is everything else.
    </p>

    <nav aria-label="Site sections" class="mt-9">
      <ul class="flex flex-wrap justify-center gap-2">
        <li>
          <a href="/" class="chip transition-colors hover:border-accent hover:text-accent">
            Home
          </a>
        </li>
        {
          NAV_ITEMS.map((item) => (
            <li>
              <a
                href={item.href}
                class="chip transition-colors hover:border-accent hover:text-accent"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <a href="/" class="btn btn-primary mt-10">
      <svg
        class="size-4"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M19 12H5M11 18l-6-6 6-6"></path>
      </svg>
      Back to home
    </a>
  </section>
</BaseLayout>
