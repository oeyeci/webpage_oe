---
/**
 * Vertical timeline.
 *
 * Semantically an ordered list — a screen-reader user hears "list, 6 items",
 * which is the correct mental model for a chronology. The connecting rail and
 * the nodes are pure CSS pseudo-decoration and are hidden from assistive tech.
 */
import type { TimelineEntry } from './timeline';

interface Props {
  entries: TimelineEntry[];
}

const { entries } = Astro.props;
---

<ol class="relative space-y-0">
  {
    entries.map((entry, index) => (
      <li class="reveal relative grid grid-cols-[auto_1fr] gap-x-5 pb-10 last:pb-0">
        {/* Rail + node */}
        <div class="relative flex flex-col items-center" aria-hidden="true">
          <span
            class:list={[
              'mt-1.5 grid size-3 shrink-0 place-items-center rounded-full ring-4',
              entry.isCurrent
                ? 'bg-accent ring-accent-soft'
                : 'bg-line-strong ring-paper',
            ]}
          >
            {entry.isCurrent && (
              <span class="absolute size-3 animate-ping rounded-full bg-accent opacity-40" />
            )}
          </span>
          {index < entries.length - 1 && <span class="mt-1 w-px flex-1 bg-line" />}
        </div>

        {/* Content */}
        <div class="-mt-0.5 min-w-0 pb-2">
          <p class="font-mono text-xs tracking-wide text-ink-subtle">{entry.period}</p>

          <h3 class="mt-1.5 text-lg leading-snug">
            {entry.href ? (
              <a
                href={entry.href}
                class="transition-colors hover:text-accent"
                target={entry.href.startsWith('http') ? '_blank' : undefined}
                rel={entry.href.startsWith('http') ? 'noopener noreferrer' : undefined}
              >
                {entry.title}
              </a>
            ) : (
              entry.title
            )}
          </h3>

          {entry.subtitle && (
            <p class="mt-1 text-[0.9375rem] font-medium text-ink-muted">{entry.subtitle}</p>
          )}
          {entry.meta && <p class="mt-0.5 text-sm text-ink-subtle">{entry.meta}</p>}

          {entry.descriptionHtml && (
            <div
              class="prose mt-3 !text-[0.9375rem] [&>p:first-of-type]:!text-[0.9375rem] [&>p:first-of-type]:!text-ink-muted [&>p]:!my-2"
              set:html={entry.descriptionHtml}
            />
          )}

          {entry.tags && entry.tags.length > 0 && (
            <ul class="mt-3 flex flex-wrap gap-1.5">
              {entry.tags.map((tag) => (
                <li class="chip !py-0.5 !text-xs">{tag}</li>
              ))}
            </ul>
          )}
        </div>
      </li>
    ))
  }
</ol>
