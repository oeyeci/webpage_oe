---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, lead, align = 'left' } = Astro.props;
---

<div
  class:list={[
    'container-page pt-16 pb-10 md:pt-24 md:pb-14',
    align === 'center' && 'text-center',
  ]}
>
  <div class:list={['reveal max-w-3xl', align === 'center' && 'mx-auto']}>
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1 class="mt-3 text-4xl md:text-[var(--text-title)] md:leading-[1.1] md:tracking-[-0.022em]">
      {title}
    </h1>
    {
      lead && (
        <p class="mt-5 text-lg leading-relaxed text-ink-muted md:text-xl">
          {lead}
        </p>
      )
    }
    <slot />
  </div>
</div>
