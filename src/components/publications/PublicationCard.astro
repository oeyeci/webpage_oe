---
/**
 * One publication, rendered as an IEEE reference with affordances around it.
 *
 * The site owner's name is bolded in the byline — the single most useful thing
 * a reader scanning an academic's publication list wants, and the reason the
 * schema has an `authors.is_self` flag instead of just a denormalised string.
 */
import type { PublicationWithAuthors } from '../../lib/repositories/publications';

interface Props {
  publication: PublicationWithAuthors;
  showCitations?: boolean;
}

const { publication: pub, showCitations = true } = Astro.props;

const CATEGORY_LABEL: Record<string, string> = {
  journal: 'Journal',
  conference: 'Conference',
  book: 'Book',
  chapter: 'Chapter',
  thesis: 'Thesis',
  preprint: 'Preprint',
  patent: 'Patent',
  other: 'Other',
};

const links = [
  pub.doi && { label: 'DOI', href: `https://doi.org/${pub.doi}` },
  pub.pdfUrl && { label: 'PDF', href: pub.pdfUrl },
  pub.arxivId && { label: 'arXiv', href: `https://arxiv.org/abs/${pub.arxivId}` },
  pub.codeUrl && { label: 'Code', href: pub.codeUrl },
  pub.projectUrl && { label: 'Project', href: pub.projectUrl },
  pub.slidesUrl && { label: 'Slides', href: pub.slidesUrl },
  !pub.doi && pub.url && { label: 'Link', href: pub.url },
].filter(Boolean) as Array<{ label: string; href: string }>;

const venue = pub.journal ?? pub.booktitle ?? pub.publisher ?? pub.school ?? null;
---

<article
  id={pub.citeKey}
  class="card card-interactive scroll-mt-28 p-5 md:p-6"
  data-category={pub.category}
  data-year={pub.year}
  data-title={pub.title.toLowerCase()}
  data-authors={pub.authorsRaw.toLowerCase()}
  data-venue={(venue ?? '').toLowerCase()}
>
  <div class="flex flex-wrap items-center gap-2">
    <span class="chip chip-accent !py-0.5 !text-xs">{CATEGORY_LABEL[pub.category]}</span>
    {pub.isFeatured && <span class="chip !py-0.5 !text-xs">Selected</span>}
    {
      showCitations && pub.citationCount > 0 && (
        <span class="chip !py-0.5 !text-xs" title="Citations">
          <svg
            class="size-3"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <path d="M12 2l2.6 6.6L22 9.3l-5 4.8 1.2 7L12 17.8 5.8 21l1.2-7-5-4.8 7.4-.7z" />
          </svg>
          {pub.citationCount} {pub.citationCount === 1 ? 'citation' : 'citations'}
        </span>
      )
    }
    <span class="ml-auto font-mono text-xs text-ink-subtle">{pub.year || '—'}</span>
  </div>

  <h3 class="mt-3 text-[1.0625rem] leading-snug font-semibold">
    {pub.title}
  </h3>

  {/* Byline with the owner highlighted. */}
  {
    pub.authorList.length > 0 && (
      <p class="mt-2 text-sm leading-relaxed text-ink-muted">
        {pub.authorList.map((author, index) => (
          <>
            {author.isSelf ? (
              <strong class="font-semibold text-ink">{author.fullName}</strong>
            ) : (
              <span>{author.fullName}</span>
            )}
            {index < pub.authorList.length - 1 && <span>, </span>}
          </>
        ))}
      </p>
    )
  }

  {
    venue && (
      <p class="mt-1.5 text-sm italic text-ink-subtle">
        {venue}
        {pub.volume && <>, vol. {pub.volume}</>}
        {pub.number && <>, no. {pub.number}</>}
        {pub.pages && <>, pp. {pub.pages}</>}
      </p>
    )
  }

  <div class="mt-4 flex flex-wrap items-center gap-1.5">
    {
      links.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="chip transition-colors hover:border-accent hover:text-accent"
        >
          {link.label}
          <span class="sr-only"> for “{pub.title}” (opens in a new tab)</span>
        </a>
      ))
    }

    <button
      type="button"
      class="chip cursor-pointer transition-colors hover:border-accent hover:text-accent js-copy-citation"
      data-citation={pub.ieeeCitation}
      data-label="Cite"
    >
      Cite
      <span class="sr-only"> — copy the IEEE citation for “{pub.title}”</span>
    </button>

    <a
      href={`/publications/${pub.citeKey}.bib`}
      class="chip transition-colors hover:border-accent hover:text-accent"
      download
    >
      BibTeX
      <span class="sr-only"> for “{pub.title}”</span>
    </a>
  </div>

  {/* The full IEEE reference, available to anyone who wants to read or copy it. */}
  <details class="group mt-3">
    <summary
      class="inline-flex cursor-pointer list-none items-center gap-1 text-xs font-medium text-ink-subtle transition-colors hover:text-ink"
    >
      <svg
        class="size-3 transition-transform group-open:rotate-90"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M9 18l6-6-6-6" />
      </svg>
      IEEE reference
    </summary>
    <p
      class="mt-2 rounded-lg border border-line bg-surface-2 p-3 font-mono text-xs leading-relaxed text-ink-muted"
    >
      {pub.ieeeCitation}
    </p>
  </details>
</article>
