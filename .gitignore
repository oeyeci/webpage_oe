# build output
dist/
.astro/
.output/

# dependencies
node_modules/

# cloudflare / wrangler local state
.wrangler/
worker-configuration.d.ts

# secrets — never commit
.dev.vars
.env
.env.*
!.env.example

# Generated by `npm run seed:build`. Not committed because it embeds a PBKDF2
# password hash for the bootstrap admin account — regenerate it locally instead.
# The *source* of the seed (seed/publications.bib) IS committed.
seed/seed.sql

# The source CV. Contains a personal mobile number that is deliberately not
# published on the site, so it must not be published in the repository either.
*.pdf

# The original project brief — not source.
prompt.md

# Session record. Contains the admin password in plain text, so it must never
# reach the public repository.
PROJECT-LOG.md

# Working files for the portrait upload. The real asset lives in R2, not git.
portrait-source.jpg
portrait*.webp
*.crdownload

# backups
backups/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# editors / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db

# misc
*.local
coverage/
